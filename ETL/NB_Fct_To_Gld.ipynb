{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "##FCT 학력 정보  f_hr_scholar \n",
    "-----------------------------------------\n",
    " - 화이트 : 최종학력여부컬럼[LAST_YN]을 사용할수없음 (다수 회사에서 학력 여부를 표시하지않았기 때문에)\n",
    "   - 최종학교명 로직 규칙 : 졸업일자가 존재하고, 졸업일자가 더 최신인 학교, 졸업일자가 동일한 경우, 학력코드가 더 높은쪽이 최종학교명으로 찍히게 설정함\n",
    " - (추가)화이트 : 전공명[MJR_NM]은 공통테이블에서 가져온 전공명으로 가져오되 , 만약  전공명이 null 인 경우에 ,  학력 팩트 자체적으로 담겨있는 전공명으로 사용하는걸로 대체함 - 24.10.23\n",
    "   - 원래는 화이트 공통코드에서 가져온 전공명을 사용하고 있었으나, 원천테이블에서 이분화 되는 데이터들이 존재함으로 위와 같이 대체되게 설정함\n",
    "\n",
    " - 더존 : 최종학력컬럼 사용가능 [LAST_LEDU_YN = 'Y'] 일때 최종학교명으로 찍히게 설정함 \n",
    "<br>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 추가 수정사안 - 졸업일자 없을때 고등학교 졸업일자있으면 고등학교로 \n",
    "DF = spark.sql(\"\"\"\n",
    "-- 화이트 쿼리 \n",
    "WITH ranked_scholar AS (  \n",
    "        SELECT  \n",
    "            SCH.PERSON_ID,  \n",
    "            comm.CD_NM AS FIN_SCH_NM,  \n",
    "            RANK() OVER (  \n",
    "                PARTITION BY SCH.PERSON_ID  \n",
    "                ORDER BY SCH.SCH_GRD_CD DESC, COALESCE(SCH.END_YM, '999912') DESC, SCH.STA_YM DESC, comm.CD_NM ASC  \n",
    "            ) AS rn,  \n",
    "            SCH.STA_YM AS STA_YM,  \n",
    "            SCH.END_YM AS GRAD_DT,  \n",
    "            SCH.SCH_KIND_CD AS SCH_KIND_CD,  \n",
    "            SCH.SCH_GRD_CD AS SCH_GRD_CD  \n",
    "        FROM brz.white.PHM_SCHOLAR SCH  \n",
    "        LEFT JOIN brz.white.VE_FRM_CODE comm ON comm.cd_kind = 'PHM_SCH_CD' AND sch.SCH_CD = comm.cd  \n",
    "        WHERE SCH.END_YM IS NOT NULL -- 영문 학교명 포함  \n",
    "    )  \n",
    "    , final_scholar AS (  \n",
    "        SELECT  \n",
    "            PERSON_ID,  \n",
    "            FIN_SCH_NM,  \n",
    "            SCH_KIND_CD,  \n",
    "            MAX(STA_YM) AS MAX_STA_YM,  \n",
    "            MAX(GRAD_DT) AS MAX_GRAD_DT,  \n",
    "            MAX(SCH_GRD_CD) AS MAX_SCH_GRD_CD  \n",
    "        FROM ranked_scholar  \n",
    "        WHERE rn = 1  \n",
    "        GROUP BY PERSON_ID, FIN_SCH_NM, SCH_KIND_CD  \n",
    "    )  \n",
    "SELECT DISTINCT \n",
    "SCH.SUB_MAJOR_NM AS SUBMJR_NM,\n",
    "SCH.SUB_MAJOR_CD AS SUBMJR_CD,\n",
    "SCH.ENTRANCE_CD AS SCHENT_DIV_CD,\n",
    "SCH.SCH_KIND_CD AS SCH_DIV_CD,\n",
    "SCH.DAY_KIND_CD AS DAY_NIGHT_DIV_CD,\n",
    "SCH.SCH_PLACE_CD AS SCH_PLC_CD,\n",
    "SCH.SCH_PLACE_NM AS SCH_PLC_NM,\n",
    "SCH.SCH_PLACE_DET_CD AS SCH_PLC_DTLS_CD,\n",
    "SCH.SCH_PLACE_DET_NM AS PLC_REGION_DTLS,\n",
    "SCH.LAST_YN AS LAST_SCHLST_YN,\n",
    "SCH.CAREER_NUM AS CAREER_ADMIT_MTH_CNT,\n",
    "SCH.NOTE AS NOTE,\n",
    "SCH.MOD_USER_ID AS MOD_PRSN,\n",
    "SCH.MOD_DATE AS MOD_DTT,\n",
    "SCH.TZ_CD AS TZ_CD,\n",
    "SCH.TZ_DATE AS TZ_DTT,\n",
    "SCH.PHM_SCHOLAR_ID AS EMP_SCHLST_ID,\n",
    "CAST(SCH.EMP_ID AS varchar(20)) AS EMP_ID,\n",
    "SCH.PERSON_ID AS PRSNL_ID,\n",
    "SCH.STA_YM AS SCHENT_YYYYMM,\n",
    "SCH.END_YM AS GRAD_YYYYMM,\n",
    "dsch.DTL_CD AS SCHLST_CD, --학력코드 \n",
    "SCH.SCH_CD AS SCH_CD,\n",
    "cast(SCH.MAJOR_CD as VARCHAR(20)) AS MAJOR_CD,\n",
    "SCH.DOU_MAJOR_CD AS DOU_MAJOR_CD,\n",
    "SCH.DOU_MAJOR_NM AS DOU_MAJOR_NM,\n",
    "dsch.DTL_NM   AS SCHLST_NM, --학력명\n",
    "cast(comm.CD_NM AS VARCHAR(40)) AS SCH_NM, --학교명      \n",
    "coalesce(list.CD_NM, SCH.MAJOR_NM) AS MJR_NM, --공통전공명 ( 공통전공명[list.CD_NM]이 없을시, 학력테이블 자체전공명 나옴 )\n",
    "--SCH.MAJOR_NM as MJR_NM, -- 팩트 전공명\n",
    "CASE  \n",
    "        WHEN comm.CD_NM = fs.FIN_SCH_NM AND (SCH.END_YM = fs.MAX_GRAD_DT OR SCH.END_YM IS NULL) AND SCH.STA_YM = fs.MAX_STA_YM AND SCH.SCH_GRD_CD = fs.MAX_SCH_GRD_CD AND (fs.MAX_SCH_GRD_CD >= '01' OR list.CD_NM IS NOT NULL)  \n",
    "        THEN fs.FIN_SCH_NM  \n",
    "        ELSE NULL  \n",
    "    END AS LAST_SCH_NM --최종학교명    \n",
    "FROM brz.white.PHM_SCHOLAR SCH   \n",
    "LEFT JOIN brz.white.VE_FRM_CODE comm ON comm.cd_kind = 'PHM_SCH_CD' AND sch.SCH_CD = comm.cd     \n",
    "LEFT JOIN brz.white.VE_FRM_CODE list  ON list.cd_kind = 'PHM_MAJOR_CD' AND sch.MAJOR_CD = list.cd --공통코드에서 전공명구분 \n",
    "LEFT JOIN <catalog>.apps.m_com_hr_itg_cd_mn dsch ON dsch.df_cd = 'LaSchRatCl' AND sch.SCH_GRD_CD = dsch.Value1 --공통코드에서 학력구분\n",
    "left join gld.default.d_hr_school grad on sch.SCH_GRD_CD = grad.SCHL_CD  \n",
    "LEFT JOIN final_scholar fs ON fs.PERSON_ID = SCH.PERSON_ID\n",
    "\n",
    "UNION\n",
    "-- 더존 쿼리\n",
    "SELECT \n",
    "NULL AS SUBMJR_NM,\n",
    "NULL AS SUBMJR_CD,\n",
    "NULL AS SCHENT_DIV_CD,\n",
    "NULL AS SCH_DIV_CD,\n",
    "NULL AS DAY_NIGHT_DIV_CD,\n",
    "NULL AS SCH_PLC_CD,\n",
    "NULL AS SCH_PLC_NM,\n",
    "NULL AS SCH_PLC_DTLS_CD,\n",
    "NULL AS PLC_REGION_DTLS,\n",
    "sch.LAST_LEDU_YN as LAST_SCHLST_YN,\n",
    "NULL AS CAREER_ADMIT_MTH_CNT,\n",
    "NULL AS NOTE,\n",
    "NULL AS MOD_PRSN,\n",
    "sch.UPDATE_DTS as MOD_DTT,\n",
    "NULL AS TZ_CD,\n",
    "NULL AS TZ_DTT,\n",
    "NULL AS EMP_SCHLST_ID,\n",
    "CASE\n",
    "WHEN sch.COMPANY_CD = '3000' THEN 'a' || sch.EMP_NO -- Company A\n",
    "WHEN sch.COMPANY_CD = '2000' THEN 'q' || sch.EMP_NO -- Company B\n",
    "WHEN sch.COMPANY_CD = '1000' THEN 'f' || sch.EMP_NO -- Company C\n",
    "ELSE sch.EMP_NO\n",
    "END AS EMP_ID,\n",
    "NULL AS PRSNL_ID,\n",
    "TO_CHAR(TO_DATE(sch.MTRC_DT, 'yyyyMMdd'), 'yyyyMM') AS SCHENT_YYYYMM,  -- MTRC_DT를 VARCHAR(6)으로 변환\n",
    "TO_CHAR(TO_DATE(sch.GRDT_DT, 'yyyyMMdd'), 'yyyyMM') AS GRAD_YYYYMM,     -- GRDT_DT를 VARCHAR(6)으로 변환\n",
    "COALESCE(dicd.DTL_CD, docd.DTL_CD, stcd.DTL_CD, NULL ) AS SCHLST_CD, --학력코드\n",
    "sch.SCHL_CD as SCH_CD,\n",
    "cast (sch.DMJ_CD as VARCHAR(20)) as MAJOR_CD,\n",
    "sch.PL_MJR_CD as DOU_MAJOR_CD,\n",
    "sch.PL_MJR_NM as DOU_MAJOR_NM,\n",
    "COALESCE(dicd.DTL_NM, docd.DTL_NM, stcd.DTL_NM, NULL ) AS SCHLST_NM, -- 학력명  \n",
    "cast (sch.SCHL_NM  as VARCHAR(40))as SCH_NM,\n",
    "sch.MJR_NM as MJR_NM,\n",
    "CASE\n",
    "WHEN sch.LAST_LEDU_YN = 'Y' THEN SCHL_NM -- LAST_LEDU_YN이 'Y'일 때 SCHL_NM을 출력\n",
    "ELSE NULL\n",
    "END AS LAST_SCH_NM\n",
    "from slv.dzn.HR_SCHOCARE_MST sch\n",
    "LEFT JOIN (\n",
    "    SELECT DISTINCT DTL_CD, DTL_NM, Value7 FROM <catalog>.apps.m_com_hr_itg_cd_mn WHERE df_cd = 'LaSchRatCl' AND Value7 IS NOT NULL\n",
    ") dicd ON dicd.Value7 = sch.LEDU_CD AND sch.COMPANY_CD = '3000' --학력\n",
    "LEFT JOIN (\n",
    "    SELECT DISTINCT DTL_CD, DTL_NM, Value3 FROM <catalog>.apps.m_com_hr_itg_cd_mn WHERE df_cd = 'LaSchRatCl' AND Value3 IS NOT NULL\n",
    ") docd ON docd.Value3 = sch.LEDU_CD AND sch.COMPANY_CD = '1000' --학력 \n",
    "LEFT JOIN (\n",
    "    SELECT DISTINCT DTL_CD, DTL_NM, Value5 FROM <catalog>.apps.m_com_hr_itg_cd_mn WHERE df_cd = 'LaSchRatCl' AND Value5 IS NOT NULL\n",
    ") stcd ON stcd.Value5 = sch.LEDU_CD AND sch.COMPANY_CD = '2000' --학력 \n",
    "where COMPANY_CD in ('1000', '2000' , '3000')\n",
    "\"\"\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DF.write.mode(\"overwrite\").save(\"abfss://gld@<storage-account>.dfs.core.windows.net/f_hr_scholar\");"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "%%sql\n",
    "USE gld.default;\n",
    "CREATE TABLE IF NOT EXISTS f_hr_scholar\n",
    "USING DELTA\n",
    "LOCATION 'abfss://gld@<storage-account>.dfs.core.windows.net/f_hr_scholar';"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "%%sql\n",
    "select count(*) from gld.default.f_hr_scholar"
   ]
  }
